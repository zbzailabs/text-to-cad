# CAD Viewer local development defaults.
# Start from the repo root, then open the printed URL with ?dir=/absolute/path:
# npm --prefix viewer run dev -- --host 127.0.0.1

VIEWER_ASSET_BACKEND=local-fs

# Optional local settings.
# VIEWER_DEFAULT_FILE=assemblies/robot-arm/robot-arm.step
# VIEWER_GITHUB_URL=https://github.com/<owner>/<repo>
# VIEWER_ALLOWED_HOSTS=localhost,127.0.0.1
# VIEWER_MOVEIT2_WS_URL=ws://127.0.0.1:8765
# VIEWER_CAD_PYTHON=./.venv/bin/python
# VIEWER_CAD_PYTHONPATH=packages/cadpy/src
# VIEWER_SERVER_REGISTRY=/tmp/cad-viewer-servers.json

# Hosted Vercel Blob backend settings.
# VIEWER_ASSET_BACKEND=vercel-blob
# VIEWER_VERCEL_BLOB_PREFIX=https://<store-id>.public.blob.vercel-storage.com/models
# VIEWER_VERCEL_BLOB_CATALOG_PATH=catalog.json
# BLOB_READ_WRITE_TOKEN=
# VIEWER_VERCEL_BLOB_READ_WRITE_TOKEN=
